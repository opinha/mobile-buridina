{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "dev:api": "pnpm --filter @workspace/api-server run dev",
    "dev:web": "pnpm --filter @workspace/aldeias-web run dev",
    "dev:app": "pnpm --filter @workspace/aldeias-app run start",
    "app:android": "pnpm --filter @workspace/aldeias-app run android",
    "app:build": "pnpm --filter @workspace/aldeias-app run build:apk",
    "build": "pnpm run typecheck:libs && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "vercel-build": "pnpm -r --filter \"./artifacts/aldeias-web\" run build"
  },
  "private": true,
  "devDependencies": {
    "typescript": "~5.9.2",
    "prettier": "^3.8.1"
  }
}
