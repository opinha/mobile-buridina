{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/artifacts/aldeias-web/dist/$1"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/artifacts/aldeias-web/dist/index.html"
    }
  ]
}
